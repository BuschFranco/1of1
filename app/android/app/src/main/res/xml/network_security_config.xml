<?xml version="1.0" encoding="utf-8"?>
<!-- Beta LAN: el backend corre en la PC del dev sin TLS. Permitimos HTTP
     SOLO hacia esa IP (no cleartext global). Al pasar a un hosting con
     https, borrar este archivo y el atributo networkSecurityConfig. -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.0.62</domain>
    </domain-config>
</network-security-config>
