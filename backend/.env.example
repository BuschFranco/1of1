# Copiá este archivo a `.env` y completá los valores. `.env` NO se commitea.

# Puerto del servidor.
PORT=3000

# Secreto para firmar los JWT (poné algo largo y aleatorio).
JWT_SECRET=cambiame-por-un-secreto-largo-y-aleatorio
JWT_EXPIRES_IN=30d

# Notion — el token vive SOLO acá (server-side), ya no en la app.
NOTION_TOKEN=
NOTION_DB_USERS=42c859d28f854f2cb004a8a68fd7b374
NOTION_DB_PROFILES=38505f6959d44e968b537afe66459657
NOTION_DB_COURTS=bda471e99e2f420887a0ca441ae68488
NOTION_DB_REVIEWS=a878279779174b7baecb13a8c1fbf9dc
NOTION_DB_PICKUPS=e4e76d276ec34012be0b36ba1f5ed133
NOTION_DB_FRIENDS=a83f5d37fae54973ae106698c83545fa
NOTION_DB_MATCHES=39952fcd7ece81408da4f331c0979c77
# Chat de crew (metadata): vacío = feature apagada.
NOTION_DB_CHATS=

# Google sign-in: client IDs permitidos (aud del idToken), separados por coma.
# Vacío en dev = no se restringe el aud.
GOOGLE_CLIENT_IDS=

# CORS: origen permitido de la app (en dev suele no aplicar a apps móviles).
CORS_ORIGIN=*
