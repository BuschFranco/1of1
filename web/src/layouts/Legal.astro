---
import Base from './Base.astro';

interface Props {
  title: string;
  updated: string;
}
const { title, updated } = Astro.props;
---

<Base title={`${title} — 1of1`} description={`${title} de la app 1of1.`}>
  <article class="legal container">
    <p class="eyebrow reveal">1of1</p>
    <h1 class="reveal">{title}</h1>
    <p class="legal-updated reveal">Última actualización: {updated}</p>

    <div class="legal-body reveal">
      <slot />
    </div>
  </article>
</Base>

<style>
  .legal {
    max-width: 780px;
    padding-top: clamp(48px, 8vh, 88px);
  }
  .legal h1 {
    font-size: clamp(34px, 6vw, 56px);
    margin-top: 14px;
    text-transform: uppercase;
  }
  .legal-updated {
    margin-top: 16px;
    color: var(--ink-45);
    font-size: 14px;
  }
  .legal-body {
    margin-top: 40px;
  }
  .legal-body :global(h2) {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 14px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 40px;
    margin-bottom: 14px;
  }
  .legal-body :global(p) {
    color: var(--ink-70);
    font-size: 16.5px;
    line-height: 1.7;
    margin-bottom: 14px;
  }
  .legal-body :global(ul) {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 8px 0 18px;
  }
  .legal-body :global(li) {
    position: relative;
    padding-left: 22px;
    color: var(--ink-70);
    font-size: 16.5px;
    line-height: 1.65;
  }
  .legal-body :global(li)::before {
    content: '';
    position: absolute;
    left: 2px;
    top: 11px;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
  }
  .legal-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .legal-body :global(strong) {
    color: var(--ink);
    font-weight: 700;
  }
</style>
