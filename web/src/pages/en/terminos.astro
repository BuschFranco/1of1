---
import Logo from '../../components/Logo.astro';
import LangSelector from '../../components/LangSelector.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('en');
const terms = t.terms;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/logo_1of1.png`} />
  <title>Terms & Conditions — 1OF1</title>
  <meta name="theme-color" content="#0d141e" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Narrow:wght@400;500;600;700&family=Anybody:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body { background: #0d141e; color: #dde2f1; overflow-x: hidden; font-family: 'Archivo Narrow', sans-serif; }
    a { color: inherit; text-decoration: none; }
    img { display: block; max-width: 100%; }
    ul { list-style: none; }
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: #080e18; }
    ::-webkit-scrollbar-thumb { background: #ff6b1a; }
  </style>
</head>
<body>

  <!-- LOADER -->
  <div id="loader" style="position:fixed;inset:0;z-index:9999;background:#0d141e;display:flex;align-items:center;justify-content:center;transition:opacity 0.8s ease, visibility 0.8s ease;">
    <Logo size={80} />
  </div>

  <!-- NAVBAR -->
  <nav style="position:fixed;top:0;width:100%;z-index:50;background:rgba(13,20,30,0.9);backdrop-filter:blur(12px);border-bottom:2px solid #5a4137;">
    <div style="max-width:1200px;margin:0 auto;padding:0 64px;display:flex;align-items:center;justify-content:space-between;height:80px;">
      <a href="/en/" style="display:flex;align-items:center;"><Logo size={40} /></a>
      <LangSelector current="en" />
      <div style="display:flex;gap:32px;">
        <a href="/en/" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#e2bfb2;font-style:italic;">Home</a>
        <a href="/en/terminos" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#ff6b1a;font-style:italic;">Terms</a>
        <a href="/en/privacidad" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#e2bfb2;font-style:italic;">Privacy</a>
      </div>
      <a href="/en/" style="transform:skewX(-8deg);display:inline-flex;align-items:center;justify-content:center;padding:12px 32px;background:#ff6b1a;color:#591e00;font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;font-style:italic;">
        <span style="transform:skewX(8deg);">{terms.back}</span>
      </a>
    </div>
  </nav>

  <!-- CONTENT -->
  <main style="max-width:780px;margin:0 auto;padding:120px 64px 80px;">
    <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:0.1em;color:#ff6b1a;font-style:italic;">{terms.badge}</span>
    <h1 style="font-family:'Anton',sans-serif;font-size:clamp(34px,6vw,56px);font-style:italic;text-transform:uppercase;color:#fff;margin-top:14px;">{terms.title}</h1>
    <p style="color:#a98a7e;font-size:14px;margin-top:16px;">{terms.updated}</p>

    <div style="margin-top:40px;">
      <p style="color:#e2bfb2;font-size:16.5px;line-height:1.7;margin-bottom:14px;">{terms.intro}</p>

      {terms.sections.map((s: any) => (
        <>
          <h2 style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;letter-spacing:0.14em;text-transform:uppercase;color:#ff6b1a;margin-top:40px;margin-bottom:14px;">{s.heading}</h2>
          <p style="color:#e2bfb2;font-size:16.5px;line-height:1.7;margin-bottom:14px;">{s.body}</p>
        </>
      ))}

      <h2 style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;letter-spacing:0.14em;text-transform:uppercase;color:#ff6b1a;margin-top:40px;margin-bottom:14px;">{terms.contactLabel}</h2>
      <p style="color:#e2bfb2;font-size:16.5px;line-height:1.7;margin-bottom:14px;"><a href={`mailto:${terms.email}`} style="color:#ff6b1a;text-decoration:underline;text-underline-offset:2px;">{terms.email}</a></p>
    </div>
  </main>

  <!-- FOOTER -->
  <footer style="padding:32px 0;background:#080e18;border-top:2px solid #5a4137;">
    <div style="max-width:1200px;margin:0 auto;padding:0 64px;display:flex;flex-direction:column;align-items:center;gap:16px;">
      <Logo size={32} />
      <div style="display:flex;flex-wrap:wrap;justify-content:center;gap:32px;">
        <a href="/en/" style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#2f3132;">Home</a>
        <a href="/en/terminos" style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#2f3132;">Terms</a>
        <a href="/en/privacidad" style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#2f3132;">Privacy</a>
      </div>
      <div style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#2f3132;opacity:0.5;text-transform:uppercase;letter-spacing:0.1em;">© 2024 1OF1 BASKETBALL. ALL RIGHTS RESERVED.</div>
    </div>
  </footer>

  <script is:inline>
    window.addEventListener('load', () => {
      const loader = document.getElementById('loader');
      setTimeout(() => { loader.style.opacity = '0'; loader.style.visibility = 'hidden'; }, 600);
    });
  </script>

</body>
</html>
