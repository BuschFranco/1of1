---
import Logo from '../../components/Logo.astro';
import LangSelector from '../../components/LangSelector.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('en');
const features = t.features.items;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/logo_1of1.png`} />
    <title>1OF1 Basketball — Find court. Play. Log every game.</title>
    <meta name="description" content="1of1 is the basketball app to find courts nearby, log your games automatically and track your progress: stats, rankings and achievements." />
    <meta name="theme-color" content="#0d141e" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo+Narrow:wght@400;500;600;700&family=Anybody:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { background: #0d141e; color: #dde2f1; overflow-x: hidden; font-family: 'Archivo Narrow', sans-serif; }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }
      ul { list-style: none; }
      .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
      ::-webkit-scrollbar { width: 8px; }
      ::-webkit-scrollbar-track { background: #080e18; }
      ::-webkit-scrollbar-thumb { background: #ff6b1a; }
      .btn-active:active { transform: skewX(-8deg) scale(0.95); }
      .nav-link { transition: color 0.2s, transform 0.2s; }
      .nav-link:hover { color: #ff6b1a; transform: skewX(-4deg); }
      .card-hover { transition: border-color 0.2s, transform 0.2s; }
      .card-hover:hover { border-color: #ff6b1a; transform: translateY(-4px); }
      .cta-btn { transition: background 0.2s, color 0.2s, box-shadow 0.2s; }
      .cta-btn:hover { background: rgba(255,107,26,0.15); box-shadow: 0 0 20px rgba(255,107,26,0.3); }
      .reveal { opacity: 0; transition: opacity 0.7s ease, transform 0.7s ease; }
      .reveal.reveal-left { transform: translateX(-60px); }
      .reveal.reveal-right { transform: translateX(60px); }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
    </style>
  </head>
  <body>
    <!-- LOADER -->
    <div id="loader" style="position:fixed;inset:0;z-index:9999;background:#0d141e;display:flex;align-items:center;justify-content:center;transition:opacity 0.8s ease, visibility 0.8s ease;">
      <Logo size={80} />
    </div>

    <!-- NAVBAR -->
    <nav style="position:fixed;top:0;width:100%;z-index:50;background:rgba(13,20,30,0.9);backdrop-filter:blur(12px);border-bottom:2px solid #5a4137;">
      <div style="max-width:1200px;margin:0 auto;padding:0 64px;display:flex;align-items:center;justify-content:space-between;height:80px;">
        <a href={`${import.meta.env.BASE_URL}/en/`} style="display:flex;align-items:center;"><Logo size={72} /></a>
        <LangSelector current="en" />
        <div style="display:flex;gap:32px;">
          <a href="#features" class="nav-link" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#e2bfb2;font-style:italic;">{t.nav.features}</a>
          <a href="#stats" class="nav-link" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#e2bfb2;font-style:italic;">{t.nav.stats}</a>
          <a href="#descargar" class="nav-link" style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:#e2bfb2;font-style:italic;">{t.nav.download}</a>
        </div>
        <a href="#descargar" class="btn-active" style="transform:skewX(-8deg);display:inline-flex;align-items:center;justify-content:center;padding:12px 32px;background:#ff6b1a;color:#591e00;font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;letter-spacing:0.1em;font-style:italic;transition:all 0.2s;cursor:pointer;">
          <span style="transform:skewX(8deg);">{t.nav.getApp}</span>
        </a>
      </div>
    </nav>

    <!-- HERO -->
    <section style="position:relative;min-height:90vh;display:flex;align-items:center;overflow:hidden;padding-top:80px;">
      <div style={`position:absolute;inset:0;background-image:url(${import.meta.env.BASE_URL}/hero-bg.png);background-size:auto 100%;background-position:right center;background-repeat:no-repeat;`}></div>
      <div style="position:absolute;inset:0;background:linear-gradient(to right, #0d141e 35%, rgba(13,20,30,0.3) 70%, transparent);"></div>
      <div style="max-width:1200px;margin:0 auto;padding:0 64px;position:relative;z-index:10;width:100%;">
        <div style="display:flex;flex-direction:column;align-items:flex-start;gap:16px;max-width:620px;">
          <span style="display:inline-block;background:#ff6b1a;color:#591e00;padding:6px 12px;font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;font-style:italic;text-transform:uppercase;letter-spacing:0.1em;transform:skewX(-8deg);margin-bottom:16px;">{t.hero.badge}</span>
          <h1 style="font-family:'Anton',sans-serif;font-size:120px;line-height:0.9;font-style:italic;text-transform:uppercase;letter-spacing:-0.02em;color:#fff;">{t.hero.title1} <br/> <span style="color:#ff6b1a;text-shadow:0 0 20px rgba(255,107,26,0.4);">{t.hero.title2}</span></h1>
          <p style="font-family:'Archivo Narrow',sans-serif;font-size:18px;color:#e2bfb2;max-width:500px;margin-top:16px;">{t.hero.subtitle}</p>
          <div style="display:flex;flex-wrap:wrap;gap:16px;margin-top:32px;">
            <a href="#descargar" class="btn-active" style="transform:skewX(-8deg);display:inline-flex;align-items:center;justify-content:center;padding:20px 40px;background:#ff6b1a;color:#591e00;font-family:'Anybody',sans-serif;font-weight:800;font-size:18px;text-transform:uppercase;font-style:italic;box-shadow:0 0 30px rgba(255,107,26,0.3);transition:all 0.2s;cursor:pointer;">
              <span style="transform:skewX(8deg);">{t.hero.cta1}</span>
            </a>
            <a href="#features" class="btn-active" style="transform:skewX(-8deg);display:inline-flex;align-items:center;justify-content:center;padding:20px 40px;background:transparent;color:#fff;border:2px solid #fff;font-family:'Anybody',sans-serif;font-weight:800;font-size:18px;text-transform:uppercase;font-style:italic;transition:all 0.2s;cursor:pointer;" onmouseover="this.style.background='#fff';this.style.color='#0d141e'" onmouseout="this.style.background='transparent';this.style.color='#fff'">
              <span style="transform:skewX(8deg);">{t.hero.cta2}</span>
            </a>
          </div>
        </div>
      </div>
      <div style="position:absolute;bottom:-40px;left:0;width:100%;overflow:hidden;pointer-events:none;opacity:0.08;">
        <h2 style="font-family:'Anton',sans-serif;font-size:250px;font-style:italic;text-transform:uppercase;color:#fff;white-space:nowrap;text-shadow:0 0 40px rgba(0,0,0,0.7),0 0 80px rgba(0,0,0,0.4);">CHAMPIONS ONLY CHAMPIONS ONLY CHAMPIONS ONLY</h2>
      </div>
    </section>

    <!-- FEATURES -->
    <section id="features" style="padding:80px 0;background:#080e18;">
      <div style="max-width:1200px;margin:0 auto;padding:0 64px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;border-bottom:2px solid #5a4137;padding-bottom:16px;">
          <h2 style="font-family:'Anton',sans-serif;font-size:48px;font-style:italic;text-transform:uppercase;color:#fff;">{t.features.title}</h2>
          <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;letter-spacing:0.1em;color:#ff6b1a;font-style:italic;">{t.features.eyebrow}</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
          <!-- Feature 1: FIND YOUR COURT -->
          <div class="card-hover reveal reveal-left" style="background:#1a202a;border:1px solid #5a4137;padding:32px;display:flex;flex-direction:column;gap:16px;position:relative;overflow:hidden;">
            <span class="material-symbols-outlined" style="font-size:48px;color:#ff6b1a;">location_on</span>
            <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;text-transform:uppercase;color:#fff;">{features[0].title}</h3>
            <p style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#e2bfb2;">{features[0].body}</p>
            <div style="margin-top:auto;padding-top:16px;">
              <div style="position:relative;height:160px;width:100%;overflow:hidden;">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuBRJvLLA6M1Mbi0b--QP_DPhA6sRLvgSumaLmZrj8YWLkiTmoevV0xJgyXyCvaN4mP9jk98hwkZiWczU4tyrDow5G3vzvcfpK2FjvgH-dU1oK1r-_I8c2sX-1SHN4yDYyVjO6ohf_I_7JBF0gsYAiaHyoh8MIiSyYPEF8jCqDylmIkboJZX9ONjJNYHGkn3SGSCXGDkiL67zV-v6PSREFQhhorbM0yjoHQtCPBVrCPMEUZ0jJBWtT5CxsCmgup4l-qQ9NsgX9Diojs" alt="Court map" style="width:100%;height:100%;object-fit:cover;filter:grayscale(1);transition:filter 0.5s;" onmouseover="this.style.filter='grayscale(0)'" onmouseout="this.style.filter='grayscale(1)'" />
                <div style="position:absolute;inset:0;background:rgba(255,107,26,0.15);mix-blend-mode:overlay;"></div>
              </div>
            </div>
          </div>
          <!-- Feature 2: GPS GAME TRACKER -->
          <div class="card-hover reveal reveal-left" style="background:#1a202a;border:1px solid #5a4137;padding:32px;display:flex;flex-direction:column;gap:16px;position:relative;overflow:hidden;">
            <span class="material-symbols-outlined" style="font-size:48px;color:#ff6b1a;">distance</span>
            <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;text-transform:uppercase;color:#fff;">{features[1].title}</h3>
            <p style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#e2bfb2;">{features[1].body}</p>
            <div style="margin-top:auto;padding-top:16px;position:relative;height:120px;width:100%;overflow:hidden;border:1px solid #5a4137;background:#080e18;">
              <div style="position:absolute;top:50%;left:0;width:100%;height:1px;background:#5a4137;opacity:0.3;"></div>
              <div style="position:absolute;left:50%;top:0;width:1px;height:100%;background:#5a4137;opacity:0.3;"></div>
              <div style="position:absolute;top:30%;left:20%;width:6px;height:6px;background:#ff6b1a;border-radius:50%;box-shadow:0 0 8px rgba(255,107,26,0.8);"></div>
              <div style="position:absolute;top:60%;left:45%;width:8px;height:8px;background:#ff6b1a;border-radius:50%;box-shadow:0 0 10px rgba(255,107,26,0.8);"></div>
              <div style="position:absolute;top:40%;left:70%;width:5px;height:5px;background:#ff6b1a;border-radius:50%;box-shadow:0 0 6px rgba(255,107,26,0.6);opacity:0.7;"></div>
              <div style="position:absolute;bottom:8px;left:8px;font-family:'Anybody',sans-serif;font-weight:800;font-size:10px;color:#ff6b1a;text-transform:uppercase;letter-spacing:0.1em;font-style:italic;">LIVE TRACKING</div>
            </div>
          </div>
          <!-- Feature 3: ELITE STATS -->
          <div class="card-hover reveal reveal-right" style="background:#1a202a;border:1px solid #5a4137;padding:32px;display:flex;flex-direction:column;gap:16px;position:relative;overflow:hidden;">
            <span class="material-symbols-outlined" style="font-size:48px;color:#ff6b1a;">analytics</span>
            <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;text-transform:uppercase;color:#fff;">{features[2].title}</h3>
            <p style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#e2bfb2;">{features[2].body}</p>
            <div style="margin-top:auto;padding-top:16px;display:flex;flex-direction:column;gap:8px;">
              <div style="height:8px;width:100%;background:#2f3540;"><div style="height:100%;background:#ff6b1a;width:85%;"></div></div>
              <div style="height:8px;width:100%;background:#2f3540;"><div style="height:100%;background:#ff6b1a;width:62%;"></div></div>
              <div style="height:8px;width:100%;background:#2f3540;"><div style="height:100%;background:#ff6b1a;width:94%;"></div></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- SQUAD & COMMUNITY -->
    <section style="padding:80px 0;background:#0d141e;position:relative;overflow:hidden;">
      <div style={`position:absolute;inset:0;background-image:url(${import.meta.env.BASE_URL}/community-bg.png);background-size:cover;background-position:center;`}></div>
      <div style="position:absolute;inset:0;background:rgba(13,20,30,0.75);"></div>
      <div style="max-width:1200px;margin:0 auto;padding:0 64px;position:relative;z-index:1;">
        <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:32px;border-bottom:2px solid #5a4137;padding-bottom:16px;">
          <h2 style="font-family:'Anton',sans-serif;font-size:48px;font-style:italic;text-transform:uppercase;color:#fff;">{t.community.title}</h2>
          <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;letter-spacing:0.1em;color:#ff6b1a;font-style:italic;">{t.community.eyebrow}</span>
        </div>
        <div style="display:grid;grid-template-columns:8fr 4fr;gap:24px;">
          <!-- Left: Social + Pickups + Clan -->
          <div style="display:flex;flex-direction:column;gap:24px;">
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;">
              <!-- Social Hub -->
              <div class="card-hover reveal reveal-left" style="background:rgba(26,32,42,0.7);border:1px solid #5a4137;padding:32px;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                  <span class="material-symbols-outlined" style="color:#ff6b1a;font-size:32px;">group</span>
                  <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;color:#fff;">{t.community.socialHub.title}</h3>
                </div>
                <p style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#e2bfb2;margin-bottom:24px;">{t.community.socialHub.body}</p>
                <div style="display:flex;flex-direction:column;gap:8px;margin-bottom:16px;">
                  <div style="background:rgba(8,14,24,0.7);border:1px solid #5a4137;padding:10px 12px;display:flex;align-items:center;gap:10px;">
                    <div style="width:8px;height:8px;background:#4ade80;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;">
                      <div style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#fff;font-style:italic;">{t.community.socialHub.friend1}</div>
                      <div style="font-family:'Archivo Narrow',sans-serif;font-size:10px;color:#4ade80;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{t.community.socialHub.friend1Status}</div>
                    </div>
                  </div>
                  <div style="background:rgba(8,14,24,0.7);border:1px solid #5a4137;padding:10px 12px;display:flex;align-items:center;gap:10px;">
                    <div style="width:8px;height:8px;background:#4ade80;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;">
                      <div style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#fff;font-style:italic;">{t.community.socialHub.friend2}</div>
                      <div style="font-family:'Archivo Narrow',sans-serif;font-size:10px;color:#a98a7e;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{t.community.socialHub.friend2Status}</div>
                    </div>
                  </div>
                  <div style="background:rgba(8,14,24,0.7);border:1px solid #5a4137;padding:10px 12px;display:flex;align-items:center;gap:10px;">
                    <div style="width:8px;height:8px;background:#5a4137;border-radius:50%;flex-shrink:0;"></div>
                    <div style="flex:1;min-width:0;">
                      <div style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#e2bfb2;font-style:italic;">{t.community.socialHub.friend3}</div>
                      <div style="font-family:'Archivo Narrow',sans-serif;font-size:10px;color:#5a4137;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{t.community.socialHub.friend3Status}</div>
                    </div>
                  </div>
                </div>
                <div style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#ff6b1a;font-style:italic;text-transform:uppercase;">{t.community.socialHub.friendsActive}</div>
              </div>
              <!-- Pickups & Events -->
              <div class="card-hover reveal reveal-right" style="background:rgba(26,32,42,0.7);border:1px solid #5a4137;padding:32px;">
                <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
                  <span class="material-symbols-outlined" style="color:#ff6b1a;font-size:32px;">event_available</span>
                  <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;color:#fff;">{t.community.pickups.title}</h3>
                </div>
                <p style="font-family:'Archivo Narrow',sans-serif;font-size:16px;color:#e2bfb2;margin-bottom:24px;">{t.community.pickups.body}</p>
                <div style="display:flex;flex-direction:column;gap:12px;">
                  <div style="background:rgba(47,53,64,0.5);padding:12px;display:flex;justify-content:space-between;align-items:center;border-left:4px solid #ff6b1a;">
                    <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#fff;font-style:italic;">{t.community.pickups.event1}</span>
                    <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#ff6b1a;">{t.community.pickups.event1Status}</span>
                  </div>
                  <div style="background:rgba(47,53,64,0.5);padding:12px;display:flex;justify-content:space-between;align-items:center;border-left:4px solid #5a4137;">
                    <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#e2bfb2;font-style:italic;">{t.community.pickups.event2}</span>
                    <span style="font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;color:#fff;">{t.community.pickups.event2Status}</span>
                  </div>
                </div>
              </div>
            </div>
            <!-- Clan System -->
            <div class="reveal reveal-left" style="background:rgba(36,42,53,0.7);border:2px solid #ff6b1a;padding:32px;position:relative;overflow:hidden;">
              <div style="position:absolute;right:-40px;top:-40px;opacity:0.1;transform:rotate(12deg);pointer-events:none;">
                <span class="material-symbols-outlined" style="font-size:200px;">shield</span>
              </div>
              <div style="position:relative;z-index:1;">
                <span style="display:inline-block;background:#ff6b1a;color:#591e00;padding:6px 12px;font-family:'Anybody',sans-serif;font-weight:800;font-size:12px;font-style:italic;text-transform:uppercase;letter-spacing:0.1em;transform:skewX(-8deg);margin-bottom:16px;">{t.community.clan.badge}</span>
                <h3 style="font-family:'Anton',sans-serif;font-size:48px;font-style:italic;color:#fff;margin-bottom:8px;text-transform:uppercase;">{t.community.clan.title}</h3>
                <p style="font-family:'Archivo Narrow',sans-serif;font-size:18px;color:#e2bfb2;max-width:600px;margin-bottom:24px;">{t.community.clan.body} <span style="color:#ff6b1a;font-style:italic;font-weight:700;">{t.community.clan.highlight}</span>.</p>
                <div style="display:flex;flex-wrap:wrap;gap:16px;align-items:center;">
                  <div style="background:#0d141e;border:1px solid #5a4137;padding:16px;display:flex;align-items:center;gap:12px;min-width:240px;">
                    <div style="width:48px;height:48px;background:#ff6b1a;display:flex;align-items:center;justify-content:center;">
                      <span class="material-symbols-outlined" style="color:#591e00;">sports_kabaddi</span>
                    </div>
                    <div>
                      <div style="font-family:'Archivo Narrow',sans-serif;font-size:10px;color:#e2bfb2;text-transform:uppercase;font-weight:700;">{t.community.clan.currentRulers}</div>
                      <div style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;color:#fff;text-transform:uppercase;">{t.community.clan.clanName}</div>
                    </div>
                  </div>
                  <a href="#descargar" class="btn-active" style="transform:skewX(-8deg);display:inline-flex;align-items:center;padding:16px 32px;background:#fff;color:#0d141e;font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;text-transform:uppercase;font-style:italic;transition:all 0.2s;cursor:pointer;">
                    <span style="transform:skewX(8deg);">{t.community.clan.cta}</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
          <!-- Right: Leaderboard -->
          <div class="reveal reveal-right" style="background:rgba(26,32,42,0.7);border:1px solid #5a4137;padding:32px;">
            <div style="display:flex;align-items:center;gap:12px;margin-bottom:32px;">
              <span class="material-symbols-outlined" style="color:#ff6b1a;font-size:32px;">military_tech</span>
              <h3 style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;color:#fff;text-transform:uppercase;">{t.community.leaderboard.title}</h3>
            </div>
            <div style="display:flex;flex-direction:column;gap:24px;">
              <!-- Top 1 -->
              <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:16px;border-bottom:1px solid rgba(90,65,55,0.3);">
                <div style="display:flex;align-items:center;gap:16px;">
                  <span style="font-family:'Anton',sans-serif;font-size:32px;font-style:italic;color:#ff6b1a;">01</span>
                  <div>
                    <div style="font-family:'Anybody',sans-serif;font-weight:800;font-size:14px;color:#fff;font-style:italic;">{t.community.leaderboard.rank1}</div>
