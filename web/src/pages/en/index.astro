    <script is:inline>
      // Reveal on scroll
      (function() {
        const els = document.querySelectorAll('.reveal');
        if (!els.length) return;
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          }
        }, { rootMargin: '0px 0px -8% 0px' });
        els.forEach((el) => io.observe(el));
      })();

      window.addEventListener('load', () => {
        const loader = document.getElementById('loader');
        setTimeout(() => { loader.style.opacity = '0'; loader.style.visibility = 'hidden'; }, 600);
      });
      (function() {
        let currentScroll = window.scrollY;
        let targetScroll = window.scrollY;
        const ease = 0.08;
        let isScrolling = false;
        function smoothScroll() {
          const diff = targetScroll - currentScroll;
          currentScroll += diff * ease;
          if (Math.abs(diff) > 0.5) {
            window.scrollTo(0, currentScroll);
            requestAnimationFrame(smoothScroll);
          } else {
            currentScroll = targetScroll;
            window.scrollTo(0, targetScroll);
            isScrolling = false;
          }
        }
        window.addEventListener('wheel', function(e) {
          e.preventDefault();
          targetScroll = Math.max(0, Math.min(targetScroll + e.deltaY, document.body.scrollHeight - window.innerHeight));
          if (!isScrolling) { isScrolling = true; requestAnimationFrame(smoothScroll); }
        }, { passive: false });
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
          anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
              targetScroll = target.getBoundingClientRect().top + window.scrollY - 80;
              currentScroll = window.scrollY;
              if (!isScrolling) { isScrolling = true; requestAnimationFrame(smoothScroll); }
            }
          });
        });
      })();
      document.addEventListener('mousemove', (e) => {
        const card = document.querySelector('[data-tilt]');
        if (card) {
          const rect = card.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          if (x > 0 && x < rect.width && y > 0 && y < rect.height) {
            card.style.transform = `rotateY(${((x / rect.width) - 0.5) * 20 - 10}deg) rotateX(${((y / rect.height) - 0.5) * -20 + 5}deg)`;
          } else {
            card.style.transform = `rotateY(-10deg) rotateX(5deg)`;
          }
        }
      });
    </script>
